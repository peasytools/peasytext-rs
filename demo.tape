# peasytext-rs — Text case, slugify, word count (Rust)
# Theme: Tokyo Night
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "TokyoNight"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasytext-rs — Text case, slugify, word count for Rust"
Enter
Type "# peasytext.com"
Enter
Sleep 500ms

# Run the demo
Type "cargo run --example demo 2>/dev/null"
Enter
Sleep 5s
